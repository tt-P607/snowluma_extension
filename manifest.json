{
    "name": "snowluma_extension",
    "display_name": "SnowLuma 扩展能力",
    "version": "1.0.0",
    "description": "提供 SnowLuma 的群管理、消息操作、表情回应等高级操作能力",
    "author": "言柒",
    "license": "MIT",
    "categories": [
        "chat"
    ],
    "tags": [
        "snowluma",
        "qq",
        "group-management",
        "actions"
    ],
    "dependencies": {
        "plugins": ["snowluma_adapter"],
        "components": []
    },
    "include": [
        {"component_type": "config", "component_name": "config", "dependencies": []},
        {"component_type": "action", "component_name": "mute_group_member", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "unmute_group_member", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "react_to_message", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "send_face", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "poke_group_member", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "recall_message", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "group_sign", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "kick_group_member", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "set_group_name", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "set_group_card", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "set_group_special_title", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "send_group_notice", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "action", "component_name": "delete_group_notice", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "tool", "component_name": "get_group_member_info", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "tool", "component_name": "get_group_notice", "dependencies": ["snowluma_adapter:adapter:snowluma_adapter"]},
        {"component_type": "tool", "component_name": "get_qq_face_list", "dependencies": []}
    ],
    "entry_point": "plugin.py",
    "min_core_version": "1.0.0",
    "python_dependencies": [],
    "dependencies_required": true
}
